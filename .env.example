DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=postgres://pulsetrace:pulsetrace@db:5432/pulsetrace
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
RUN_NOW_THROTTLE_RATE=10/minute
CHECK_SCHEDULER_INTERVAL_SECONDS=60
ALERT_WEBHOOK_ALLOWLIST=example.com,localhost
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO
